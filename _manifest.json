{
  "manifest_version": 2,
  "id": "github.fffold.bangumi-browse-plugin",
  "version": "1.0.0",
  "name": "Bangumi 浏览插件",
  "description": "接入 Bangumi (bgm.tv)，让你的 MaiBot 变身动画高手！支持新番速览、每日放送、单集吐槽、长评阅读、制作阵容查询，动画/游戏/书籍一网打尽。",
  "author": {
    "name": "FFFold",
    "url": "https://github.com/FFFold"
  },
  "license": "MIT",
  "urls": {
    "repository": "https://github.com/FFFold/bangumi_browse_plugin",
    "homepage": "https://github.com/FFFold/bangumi_browse_plugin",
    "documentation": "https://github.com/FFFold/bangumi_browse_plugin/blob/main/README.md",
    "issues": "https://github.com/FFFold/bangumi_browse_plugin/issues"
  },
  "host_application": {
    "min_version": "1.0.0",
    "max_version": "1.99.99"
  },
  "sdk": {
    "min_version": "2.0.0",
    "max_version": "2.99.99"
  },
  "dependencies": [
    {
      "type": "python_package",
      "name": "httpx",
      "version_spec": ">=0.25.0"
    },
    {
      "type": "python_package",
      "name": "beautifulsoup4",
      "version_spec": ">=4.11.0"
    },
    {
      "type": "python_package",
      "name": "lxml",
      "version_spec": ">=4.9.0"
    }
  ],
  "capabilities": [
    "send.text",
    "config.get"
  ],
  "i18n": {
    "default_locale": "zh-CN",
    "supported_locales": ["zh-CN"]
  }
}
